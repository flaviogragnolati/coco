{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: Attach debug server-side",
      "address": "localhost",
      "port": 9230, // port set manually @see https://github.com/vercel/next.js/issues/45697
      "request": "attach",
      // "localRoot": "${workspaceFolder}/frontend", # just if next app is not inside your root dir
      "skipFiles": [
        "<node_internals>/**"
      ],
      "type": "node"
    },
    {
      "name": "Next.js: debug server-side",
      "type": "node-terminal",
      "request": "launch",
      "command": "nvm use && pnpm run dev"
    },
    {
      "name": "Next.js: debug client-side",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000"
    },
    {
      "name": "Next.js: debug full stack",
      "type": "node-terminal",
      "request": "launch",
      "command": "nvm use && pnpm run dev",
      "serverReadyAction": {
        "pattern": "- Local:.+(https?://.+)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      }
    }
  }